PORT=8080

# Database Configuration (Supabase or Local)
# Ensure the password is URL Encoded if you are using special characters!
DATABASE_URL=postgresql://postgres.xxx:PASSWORD@aws-1-xxx.pooler.supabase.com:6543/postgres

# External APIs
GOOGLE_PLACES_API_KEY=your_google_key_here
MAPBOX_ACCESS_TOKEN=your_mapbox_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Microservice Connection
AI_SERVICE_URL=http://ai_service:8000

