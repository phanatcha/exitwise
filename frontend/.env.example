# Copy this file to `.env` and fill in real values.
# Expo CLI auto-loads .env when you run `expo start` / `expo run:*` / `eas build`.
#
# Two kinds of variables live here:
#   * EXPO_PUBLIC_*  → inlined into the JS bundle and SHIPPED ON DEVICE.
#                      Treat these as public. Safe to grep in a decompiled APK.
#   * Everything else → only visible in app.config.ts / native build steps.
#                       Use these for secrets that must not touch the JS bundle.

# ---------------------------------------------------------------------------
# Mapbox PUBLIC access token (pk.*)
#   Scope: the default public scopes are fine.
#   Used at runtime in App.tsx via Mapbox.setAccessToken(...).
#   Get it from: https://account.mapbox.com/access-tokens
# ---------------------------------------------------------------------------
EXPO_PUBLIC_MAPBOX_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Mapbox SECRET download token (sk.*)
#   Scope: DOWNLOADS:READ only (do NOT grant account-level scopes).
#   Used at build time by the @rnmapbox/maps Expo config plugin + Gradle to
#   fetch the native Mapbox SDK. Never bundled into JS. Never ships to devices.
#   Create via: https://account.mapbox.com/access-tokens → Create a token
# ---------------------------------------------------------------------------
MAPBOX_DOWNLOAD_TOKEN=sk.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Supabase (public — safe to ship to devices)
#   URL: project URL from Supabase dashboard → Project Settings → API
#   Key: the "publishable" key (sb_publishable_*) or legacy anon JWT.
#        Both are safe on device because RLS + auth.uid() gates everything.
#   Do NOT put the service_role key here; that one bypasses RLS.
# ---------------------------------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://nwzprdgrkjlxzsolpaum.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# Go backend base URL
#   * iOS simulator:  http://localhost:8080
#   * Android emu:    http://10.0.2.2:8080
#   * Physical phone: http://<your-laptop-lan-ip>:8080
# ---------------------------------------------------------------------------
EXPO_PUBLIC_API_BASE_URL=http://10.0.2.2:8080
